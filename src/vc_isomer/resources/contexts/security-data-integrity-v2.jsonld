{
  "@context": {
    "@version": 1.1,
    "sec": "https://w3id.org/security#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "DataIntegrityProof": "sec:DataIntegrityProof",
    "assertionMethod": "sec:assertionMethod",
    "created": {
      "@id": "http://purl.org/dc/terms/created",
      "@type": "xsd:dateTime"
    },
    "cryptosuite": {
      "@id": "sec:cryptosuite",
      "@type": "xsd:string"
    },
    "proof": {
      "@id": "sec:proof"
    },
    "proofPurpose": {
      "@id": "sec:proofPurpose",
      "@type": "@vocab"
    },
    "proofValue": {
      "@id": "sec:proofValue",
      "@type": "sec:multibase"
    },
    "verificationMethod": {
      "@id": "sec:verificationMethod",
      "@type": "@id"
    }
  }
}

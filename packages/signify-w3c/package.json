{
  "name": "signify-w3c",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Edge-owned W3C VC-JWT and VP-JWT artifact helpers for Signify wallets",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "prepare": "npm run build",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@noble/hashes": "^1.3.3",
    "jsonld": "^8.3.3"
  },
  "peerDependencies": {
    "signify-ts": "*"
  },
  "devDependencies": {
    "@types/jsonld": "^1.5.15",
    "@types/node": "^25.0.0",
    "signify-ts": "github:kentbull/signify-ts#4857945",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}

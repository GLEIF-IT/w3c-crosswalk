# Portable local W3C crosswalk stack inputs.
# These defaults are image tags, not local source paths. The bullctx artifact
# script builds repo-owned artifacts and writes published support image tags.

# Image Tags
KERIA_IMAGE=w3c-crosswalk/keria:holder-present
SIGNIFYPY_IMAGE=w3c-crosswalk/signifypy:holder-present
WITNESS_IMAGE=weboftrust/keri:1.2.13
VLEI_IMAGE=gleif/vlei:1.0.3
DID_WEBS_RESOLVER_IMAGE=gleif/did-webs-resolver-service:0.3.7

# Verifier Image Tags
ISOMER_PYTHON_IMAGE=w3c-crosswalk/isomer-python:holder-present
ISOMER_NODE_IMAGE=w3c-crosswalk/isomer-node:holder-present
ISOMER_GO_IMAGE=w3c-crosswalk/isomer-go:holder-present
ISOMER_DASHBOARD_IMAGE=w3c-crosswalk/isomer-dashboard:holder-present

# Config for KERIA
DID_WEBS_REGISTRY_NAME_PREFIX=didwebs-designated-aliases
DID_WEBS_PUBLIC_BASE_URL=http://host.docker.internal:3902/dws
KERIA_STATUS_BASE_URL=http://host.docker.internal:3902

# Signify wallet config
KERIA_ADMIN_URL=http://127.0.0.1:3901
KERIA_ROUTER_URL=http://127.0.0.1:3902
KERIA_BOOT_URL=http://127.0.0.1:3903

### Verifier config
# did:webs resolver config per verifier
ISOMER_RESOLVER_URL=http://did-webs-resolver:7678/1.0/identifiers

# URLs KERIA uses from inside the compose network when submitting holder VPs.
W3C_PYTHON_VERIFIER_SUBMISSION_URL=http://isomer-python:8788
W3C_NODE_VERIFIER_SUBMISSION_URL=http://isomer-node:8788
W3C_GO_VERIFIER_SUBMISSION_URL=http://isomer-go:8788
